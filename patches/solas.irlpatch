# --- option labels + tooltips (English) ---
@file shaders/lang/en_US.lang
after "option.FIREFLIES_BRIGHTNESS=Fireflies Brightness"
<<<


#IRLite Lights (BBS addon) - dynamic point/spot lights
screen.IRLITE_SETTINGS=§6IRLite Lights
option.IRLITE_DIFFUSE=§6Diffuse Light
option.IRLITE_DIFFUSE.comment=Surface lighting from the IRLite point/spot lights placed in the BBS editor.
option.IRLITE_INTENSITY=§6Master Intensity
option.IRLITE_INTENSITY.comment=Master brightness multiplier for all IRLite terms.

screen.IRLITE_SPECULAR_SETTINGS=§bSpecular
option.IRLITE_SPECULAR=§bSpecular Highlights
option.IRLITE_SPECULAR.comment=GGX highlight from IRLite lights. Applies to models, held items and block entities only - vanilla terrain stays matte.
option.IRLITE_SPECULAR_INTENSITY=§bSpecular Intensity
option.IRLITE_SPECULAR_INTENSITY.comment=Highlight brightness, multiplied with Master Intensity.
option.IRLITE_SPECULAR_SMOOTHNESS=§bSpecular Smoothness
option.IRLITE_SPECULAR_SMOOTHNESS.comment=Global lobe width - higher means tighter, mirror-like highlights.

screen.IRLITE_SHADOW_SETTINGS=§3Shadows
option.IRLITE_SHADOWS=§3Light Shadows
option.IRLITE_SHADOWS.comment=Real-time baked shadows for IRLite lights (spot atlas + point cube maps). Turning this off also removes the cube-array sampler - use it if the pack fails to compile on a strict driver.
option.IRLITE_SHADOW_QUALITY=§3Shadow Quality
option.IRLITE_SHADOW_QUALITY.comment=PCSS tap count. Hard is a single tap; higher tiers soften contact shadows. §c[-]§rAffects performance.
value.IRLITE_SHADOW_QUALITY.0=Hard
value.IRLITE_SHADOW_QUALITY.1=Low
value.IRLITE_SHADOW_QUALITY.2=Medium
value.IRLITE_SHADOW_QUALITY.3=High
value.IRLITE_SHADOW_QUALITY.4=Very High
option.IRLITE_SHADOW_SIZE=§3Light Size
option.IRLITE_SHADOW_SIZE.comment=Virtual light-source size for the penumbra, in blocks. A per-light bulb size set in BBS overrides this.
option.IRLITE_SHADOW_BIAS=§3Shadow Bias
option.IRLITE_SHADOW_BIAS.comment=Depth bias against shadow acne. Raise only if acne survives the normal offset.
option.IRLITE_SHADOW_NORMAL_OFFSET=§3Normal Offset
option.IRLITE_SHADOW_NORMAL_OFFSET.comment=Receiver nudge along the surface normal, in blocks. Kills the texel staircase without peter-panning. 0 disables.

screen.IRLITE_VL_SETTINGS=§dVolumetrics
option.IRLITE_VOLUMETRIC=§dVolumetric Light
option.IRLITE_VOLUMETRIC.comment=Per-light beams and haze, marched in a reduced-resolution pass. Per-light beam strength comes from BBS.
option.IRLITE_VL_INTENSITY=§dVL Intensity
option.IRLITE_VL_INTENSITY.comment=Brightness of the beams and haze.
option.IRLITE_VL_RESOLUTION=§dVL Resolution
option.IRLITE_VL_RESOLUTION.comment=Resolution of the volumetric pass. Half costs a quarter of Full, Quarter a sixteenth. §c[-]§rLower values may shimmer on thin beams.
value.IRLITE_VL_RESOLUTION.1.0=Full
value.IRLITE_VL_RESOLUTION.0.5=Half
value.IRLITE_VL_RESOLUTION.0.25=Quarter
option.IRLITE_VL_STEPS=§dVL Steps
option.IRLITE_VL_STEPS.comment=Ray-march samples per light. §c[-]§rAffects performance.
option.IRLITE_VL_SHADOWS=§dVL Shadows
option.IRLITE_VL_SHADOWS.comment=Per-step occlusion of the beams by the baked shadow maps - god-rays through windows. Needs Light Shadows.
option.IRLITE_VL_SHADOW_STRIDE=§dVL Shadow Stride
option.IRLITE_VL_SHADOW_STRIDE.comment=Tap the shadow map every Nth march step and reuse the result in between. §a[+]§rHigher is faster.
option.IRLITE_VL_TIP_BOOST=§dTip Glow
option.IRLITE_VL_TIP_BOOST.comment=Extra glow near the light source itself.
option.IRLITE_VL_TIP_RADIUS=§dTip Radius
option.IRLITE_VL_TIP_RADIUS.comment=Radius of the tip glow, in blocks.
option.IRLITE_VL_MAX_DIST=§dVL Max Distance
option.IRLITE_VL_MAX_DIST.comment=Ray length cap, in blocks. Keeps sky rays cheap.

screen.IRLITE_TOON_SETTINGS=§aToon
option.IRLITE_TOON=§aToon Banding
option.IRLITE_TOON.comment=Quantizes IRLite diffuse into bands - a cel-shading look.
option.IRLITE_TOON_BANDS=§aBands
option.IRLITE_TOON_BANDS.comment=Number of brightness bands.
option.IRLITE_TOON_SMOOTH=§aBand Smoothing
option.IRLITE_TOON_SMOOTH.comment=Softness of the band edges.

screen.IRLITE_OUTLINE_SETTINGS=§eRim Outline
option.IRLITE_OUTLINE=§eRim Outline
option.IRLITE_OUTLINE.comment=Light-driven contour ink on silhouettes - a line appears where an IRLite light wraps a subject from behind or the side. Covers BBS models and block entities; water never inks.
option.IRLITE_OUTLINE_TARGET=§eTarget
option.IRLITE_OUTLINE_TARGET.comment=What receives the line. Subjects means entities and block entities only - terrain stays clean.
value.IRLITE_OUTLINE_TARGET.0=Everything
value.IRLITE_OUTLINE_TARGET.1=Subjects only
option.IRLITE_OUTLINE_PIXEL_SIZE=§eLine Width
option.IRLITE_OUTLINE_PIXEL_SIZE.comment=Stroke width in pixels.
option.IRLITE_OUTLINE_STRENGTH=§eInk Strength
option.IRLITE_OUTLINE_STRENGTH.comment=Stroke brightness, on top of Master Intensity.
option.IRLITE_OUTLINE_WRAP=§eLight Wrap
option.IRLITE_OUTLINE_WRAP.comment=How far around from a pure backlight a light may sit and still ink. 0 is strict backlight, 0.5 side and back, 1 almost any angle.
option.IRLITE_OUTLINE_DEPTH_THRESHOLD=§eDepth Threshold
option.IRLITE_OUTLINE_DEPTH_THRESHOLD.comment=Silhouette sensitivity. Lower catches finer steps but may speckle at distance.
>>>

# --- option labels + tooltips (Russian вЂ” the pack ships ru_RU) ---
@file shaders/lang/ru_RU.lang
after "option.FIREFLIES_BRIGHTNESS=Яркость Светлячков"
<<<


#IRLite Lights (аддон BBS) - динамические источники света
screen.IRLITE_SETTINGS=§6IRLite Свет
option.IRLITE_DIFFUSE=§6Диффузный Свет
option.IRLITE_DIFFUSE.comment=Освещение поверхностей от поинтов и спотов IRLite, расставленных в редакторе BBS.
option.IRLITE_INTENSITY=§6Общая Яркость
option.IRLITE_INTENSITY.comment=Главный множитель яркости всех эффектов IRLite.

screen.IRLITE_SPECULAR_SETTINGS=§bБлики
option.IRLITE_SPECULAR=§bБлики
option.IRLITE_SPECULAR.comment=GGX-блик от источников IRLite. Только модели, предметы в руке и блок-энтити - ванильный террейн остаётся матовым.
option.IRLITE_SPECULAR_INTENSITY=§bЯркость Бликов
option.IRLITE_SPECULAR_INTENSITY.comment=Яркость блика, умножается на Общую Яркость.
option.IRLITE_SPECULAR_SMOOTHNESS=§bГладкость
option.IRLITE_SPECULAR_SMOOTHNESS.comment=Глобальная ширина лепестка - выше значит узкий, зеркальный блик.

screen.IRLITE_SHADOW_SETTINGS=§3Тени
option.IRLITE_SHADOWS=§3Тени Света
option.IRLITE_SHADOWS.comment=Тени от источников IRLite в реальном времени (атлас спотов + куб-карты поинтов). Выключение убирает и cube-array сэмплер - спасение, если пак не компилируется на строгом драйвере.
option.IRLITE_SHADOW_QUALITY=§3Качество Теней
option.IRLITE_SHADOW_QUALITY.comment=Число PCSS-сэмплов. Hard - один тап; выше - мягче контактные тени. §c[-]§rВлияет на производительность.
value.IRLITE_SHADOW_QUALITY.0=Жёсткие
value.IRLITE_SHADOW_QUALITY.1=Низкое
value.IRLITE_SHADOW_QUALITY.2=Среднее
value.IRLITE_SHADOW_QUALITY.3=Высокое
value.IRLITE_SHADOW_QUALITY.4=Очень Высокое
option.IRLITE_SHADOW_SIZE=§3Размер Источника
option.IRLITE_SHADOW_SIZE.comment=Виртуальный размер источника для полутени, в блоках. Пер-лайт размер лампы из BBS перекрывает это значение.
option.IRLITE_SHADOW_BIAS=§3Сдвиг Глубины
option.IRLITE_SHADOW_BIAS.comment=Биас против теневого акне. Поднимай, только если акне пережило сдвиг по нормали.
option.IRLITE_SHADOW_NORMAL_OFFSET=§3Сдвиг по Нормали
option.IRLITE_SHADOW_NORMAL_OFFSET.comment=Сдвиг ресивера вдоль нормали, в блоках. Убирает лесенку текселей без отрыва тени от объекта. 0 - выкл.

screen.IRLITE_VL_SETTINGS=§dВолюметрика
option.IRLITE_VOLUMETRIC=§dОбъёмный Свет
option.IRLITE_VOLUMETRIC.comment=Лучи и дымка от каждого источника, маршируются в пассе уменьшенного разрешения. Сила луча задаётся в BBS.
option.IRLITE_VL_INTENSITY=§dЯркость Лучей
option.IRLITE_VL_INTENSITY.comment=Яркость лучей и дымки.
option.IRLITE_VL_RESOLUTION=§dРазрешение
option.IRLITE_VL_RESOLUTION.comment=Разрешение волюметрик-пасса. Половина стоит четверть Полного, Четверть - шестнадцатую. §c[-]§rНа тонких лучах возможен шиммер.
value.IRLITE_VL_RESOLUTION.1.0=Полное
value.IRLITE_VL_RESOLUTION.0.5=Половина
value.IRLITE_VL_RESOLUTION.0.25=Четверть
option.IRLITE_VL_STEPS=§dШаги Марша
option.IRLITE_VL_STEPS.comment=Сэмплов на луч. §c[-]§rВлияет на производительность.
option.IRLITE_VL_SHADOWS=§dТени в Лучах
option.IRLITE_VL_SHADOWS.comment=Окклюзия лучей запечёнными тенями - год-рейс через окно. Нужны включённые Тени Света.
option.IRLITE_VL_SHADOW_STRIDE=§dШаг Теневых Тапов
option.IRLITE_VL_SHADOW_STRIDE.comment=Тап теневой карты каждый N-й шаг марша, между тапами результат переиспользуется. §a[+]§rВыше - быстрее.
option.IRLITE_VL_TIP_BOOST=§dСвечение у Источника
option.IRLITE_VL_TIP_BOOST.comment=Дополнительное свечение возле самой лампы.
option.IRLITE_VL_TIP_RADIUS=§dРадиус Свечения
option.IRLITE_VL_TIP_RADIUS.comment=Радиус свечения у источника, в блоках.
option.IRLITE_VL_MAX_DIST=§dМакс. Дистанция
option.IRLITE_VL_MAX_DIST.comment=Ограничение длины луча, в блоках. Держит лучи в небо дешёвыми.

screen.IRLITE_TOON_SETTINGS=§aТун
option.IRLITE_TOON=§aТун-Бандинг
option.IRLITE_TOON.comment=Квантует диффуз IRLite в полосы - сel-shading вид.
option.IRLITE_TOON_BANDS=§aПолосы
option.IRLITE_TOON_BANDS.comment=Число полос яркости.
option.IRLITE_TOON_SMOOTH=§aСглаживание Полос
option.IRLITE_TOON_SMOOTH.comment=Мягкость границ полос.

screen.IRLITE_OUTLINE_SETTINGS=§eКонтур
option.IRLITE_OUTLINE=§eРим-Контур
option.IRLITE_OUTLINE.comment=Световой контур по силуэтам - линия там, где источник IRLite огибает объект сзади или сбоку. Модели BBS и блок-энтити; вода не контурится.
option.IRLITE_OUTLINE_TARGET=§eЦель
option.IRLITE_OUTLINE_TARGET.comment=Кто получает линию. Субъекты - только энтити и блок-энтити, террейн остаётся чистым.
value.IRLITE_OUTLINE_TARGET.0=Всё
value.IRLITE_OUTLINE_TARGET.1=Только субъекты
option.IRLITE_OUTLINE_PIXEL_SIZE=§eТолщина Линии
option.IRLITE_OUTLINE_PIXEL_SIZE.comment=Толщина штриха в пикселях.
option.IRLITE_OUTLINE_STRENGTH=§eСила Чернил
option.IRLITE_OUTLINE_STRENGTH.comment=Яркость штриха, поверх Общей Яркости.
option.IRLITE_OUTLINE_WRAP=§eОхват Света
option.IRLITE_OUTLINE_WRAP.comment=Насколько вбок от контрового положения источник ещё рисует линию. 0 - строго сзади, 0.5 - сбоку и сзади, 1 - почти любой угол.
option.IRLITE_OUTLINE_DEPTH_THRESHOLD=§eПорог Глубины
option.IRLITE_OUTLINE_DEPTH_THRESHOLD.comment=Чувствительность силуэта. Ниже - ловит мелкие ступени, но может крапить вдали.
>>>
