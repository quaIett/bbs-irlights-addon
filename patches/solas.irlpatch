# --- forward diffuse + specular inside gbuffersLighting's linear window ---
@file shaders/lib/lighting/gbuffersLighting.glsl
before "void gbuffersLighting("
<<<
#define IRLITE_SURFACE_PASS
#include "/lib/irlite/irlite_lights.glsl"

>>>
after "    vec3 finalColor = diffuseAlbedo + specularHighlight * vanillaDiffuse;"
<<<

    #if defined IRLITE_ACTIVE && (defined IRLITE_DIFFUSE || defined IRLITE_SPECULAR)
    // IRLite dynamic point/spot lights: hooked inside the function's linear
    // window — albedo.rgb was pow-2.2'd above and is still the UNLIT linear
    // surface colour; finalColor is re-encoded for storage right below. Added
    // on top of finalColor so the pack's vanillaDiffuse / vanilla AO do not
    // modulate the terms (IRLite has its own NdotL — parity with the
    // Photon/Complementary/BSL ports). Entity flag is compile-time via the
    // pack's own line-1 program self-defines.
    #if defined GBUFFERS_ENTITIES || defined GBUFFERS_BLOCK || defined GBUFFERS_HAND
    bool irliteNonTerrain = true;
    #else
    bool irliteNonTerrain = false;
    #endif
    vec3 irliteDiffuse, irliteSpec;
    irlite_lightSurface(worldPos, newNormal, viewPos, irliteNonTerrain, irliteDiffuse, irliteSpec);
    // (bare #ifdef per toggle — Iris only registers a boolean option as
    // user-configurable when its name appears in a bare #ifdef/#ifndef)
    #ifdef IRLITE_DIFFUSE
    finalColor += albedo.rgb * (1.0 - metalness) * (IRLITE_INTENSITY * irliteDiffuse);
    #endif
    #ifdef IRLITE_SPECULAR
    finalColor += (IRLITE_INTENSITY * IRLITE_SPECULAR_INTENSITY) * irliteSpec;
    #endif
    #endif
>>>

# --- rim outline ink + volumetric upsample (composite1, linear colour) ---
@file shaders/programs/composite1.glsl
before "// Global Variables //"
<<<
// IRLite: included BELOW the pack's conditional uniform block - the outline
// half references near/far/depthtex0/colortex3, which the pack declares only
// under its VL/LPV_FOG/NETHER_SMOKE gate (the lib mirror-gates its own copies
// for the compiled-out case; declaration order must hold for the active one).
#define IRLITE_COMPOSITE_PASS
#include "/lib/irlite/irlite_lights.glsl"

>>>
before "\t/* DRAWBUFFERS:0 */"
<<<
	#if defined IRLITE_ACTIVE && defined IRLITE_OUTLINE
	// IRLite rim-outline ink: light-driven contour on silhouettes (see the
	// outline half in lib/irlite). Linear colour; the z0 gate skips sky
	// (==1.0) and hand (<0.56, pack depth convention - composite3 uses the
	// same constant). Flat normal from screen-space derivatives of the
	// reconstructed position - computed OUTSIDE the branch (dFdx/dFdy
	// inside non-uniform control flow is undefined), camera-facing flip
	// inside.
	float irliteZ0 = texture2D(depthtex0, texCoord).r;
	vec3 irliteONdc = vec3(texCoord, irliteZ0) * 2.0 - 1.0;
	vec4 irliteOView = gbufferProjectionInverse * vec4(irliteONdc, 1.0);
	irliteOView /= irliteOView.w;
	vec3 irliteOPlayerPos = mat3(gbufferModelViewInverse) * irliteOView.xyz + gbufferModelViewInverse[3].xyz;
	vec3 irliteONormal = cross(dFdx(irliteOPlayerPos), dFdy(irliteOPlayerPos));
	if (irliteZ0 < 1.0 && irliteZ0 > 0.56) {
		if (dot(irliteONormal, irliteOPlayerPos) > 0.0) irliteONormal = -irliteONormal;
		bool irliteOEntity = irlite_outlineEntity(ivec2(gl_FragCoord.xy));
		color += IRLITE_INTENSITY * irlite_outlineInk(irliteOPlayerPos, irliteONormal, irliteOEntity);
	}
	#endif

	#if defined IRLITE_ACTIVE && defined IRLITE_VOLUMETRIC
	// IRLite per-light volumetrics: bilinear upsample of the reduced-res
	// buffer the added deferred2 pass marched (colortex samplers are
	// LINEAR-filtered by default). Underwater/lava parity already applied
	// march-side. Colour is LINEAR here - same stage the pack adds its VL.
	color += texture2D(colortex10, texCoord).rgb;
	#endif

>>>

